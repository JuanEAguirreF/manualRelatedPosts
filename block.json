{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "manual-related-posts-pro/manual-related-posts",
  "version": "1.0.0",
  "title": "Manual Related Posts",
  "category": "widgets",
  "icon": "admin-links",
  "description": "Display manually selected posts in a responsive card grid.",
  "textdomain": "manual-related-posts-pro",
  "editorScript": "mrp-editor-script",
  "style": "mrp-style",
  "editorStyle": "mrp-editor-style",
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "attributes": {
    "selectedPosts": { "type": "array", "default": [] },
    "sectionTitle": { "type": "string" },
    "sectionSubtitle": { "type": "string" },
    "sectionTitleColor": { "type": "string" },
    "sectionTitleSize": { "type": "number" },
    "sectionTitleWeight": { "type": "string" },
    "sectionTitleAlign": { "type": "string" },
    "sectionSubtitleColor": { "type": "string" },
    "sectionSubtitleSize": { "type": "number" },
    "sectionSubtitleAlign": { "type": "string" },
    "headingSpacing": { "type": "number" },
    "columnsDesktop": { "type": "number" },
    "columnsTablet": { "type": "number" },
    "columnsMobile": { "type": "number" },
    "gap": { "type": "number" },
    "cardBackgroundColor": { "type": "string" },
    "cardBorderColor": { "type": "string" },
    "cardBorderWidth": { "type": "number" },
    "cardBorderRadius": { "type": "number" },
    "cardPadding": { "type": "number" },
    "cardShadow": { "type": "string" },
    "cardContentAlign": { "type": "string" },
    "showImage": { "type": "boolean" },
    "imageSize": { "type": "string" },
    "imageRatio": { "type": "string" },
    "imageRadius": { "type": "number" },
    "imageHeight": { "type": "number" },
    "postTitleColor": { "type": "string" },
    "postTitleSize": { "type": "number" },
    "postTitleWeight": { "type": "string" },
    "postTitleAlign": { "type": "string" },
    "postTitleClamp": { "type": "number" },
    "showExcerpt": { "type": "boolean" },
    "excerptLength": { "type": "number" },
    "excerptColor": { "type": "string" },
    "excerptSize": { "type": "number" },
    "showDate": { "type": "boolean" },
    "showCategory": { "type": "boolean" },
    "showButton": { "type": "boolean" },
    "buttonText": { "type": "string" },
    "buttonTextColor": { "type": "string" },
    "buttonBackgroundColor": { "type": "string" },
    "buttonRadius": { "type": "number" },
    "buttonAlign": { "type": "string" },
    "fullCardLink": { "type": "boolean" },
    "openInNewTab": { "type": "boolean" },
    "blockAlign": { "type": "string" }
  }
}